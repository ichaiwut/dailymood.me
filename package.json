{
  "name": "dailymood",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "db:seed:local": "wrangler d1 execute DB --local --file=./drizzle/seed.sql",
    "db:seed:prod": "wrangler d1 execute DB --remote --file=./drizzle/seed.sql",
    "db:seed:demo:local": "wrangler d1 execute DB --local --file=./drizzle/seed_demo_moods.sql",
    "db:seed:demo:prod": "wrangler d1 execute DB --remote --file=./drizzle/seed_demo_moods.sql"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@google/generative-ai": "^0.24.1",
    "@googlemaps/js-api-loader": "^2.0.2",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.11.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260502.1",
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.64.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.86.0"
  }
}
